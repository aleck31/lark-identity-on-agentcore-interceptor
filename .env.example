# Lark app credentials — copy to .env and fill in real values.
# .env is gitignored; NEVER commit real secrets. setup-lark.sh reads this file
# and writes the credentials into Secrets Manager (the runtime source of truth).
#
# From the Lark developer console:
#   App ID / App Secret          -> Credentials & Basic Info
#   Encrypt Key / Verify Token   -> Event Subscription > Encryption Strategy
LARK_APP_ID=cli_xxxxxxxxxxxxxxxx
LARK_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LARK_ENCRYPT_KEY=xxxxxxxxxxxxxxxx
LARK_VERIFICATION_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your Lark open_id (ou_...) to add to the allowlist. Leave blank to skip.
LARK_ADMIN_OPEN_ID=
